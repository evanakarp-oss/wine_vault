        "avatar_template": "/letter_avatar_proxy/v4/letter/r/e56c9b/{size}.png",
        "created_at": "2021-12-07T15:03:46.000Z",
        "cooked": "<p>It was priced in the 60\u2019s for the last vintage Jadot produced here (2017).</p>",
