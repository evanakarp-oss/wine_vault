        "cooked": "<aside class=\"onebox allowlistedgeneric\" data-onebox-src=\"https://wfkelley.com/2017/06/13/ridge-monte-bello-a-study-in-singularity/\">\n  <header class=\"source\">\n      <img src=\"https://www.wineberserkers.com/uploads/db0731/original/3X/3/3/33cfa2351bb289df57becb0932e0431a6f2c64c2.png\" class=\"site-icon\" width=\"32\" height=\"32\">\n\n      <a href=\"https://wfkelley.com/2017/06/13/ridge-monte-bello-a-study-in-singularity/\" target=\"_blank\" rel=\"noopener nofollow ugc\" title=\"09:18PM - 13 June 2017\">William Kelley \u2013 13 Jun 17</a>\n  </header>\n\n  <article class=\"onebox-body\">\n    <div class=\"aspect-image\" style=\"--aspect-ratio:247/330;\"><img src=\"https://www.wineberserkers.com/uploads/db0731/original/3X/9/4/9449a68a2e7dc9f55d6005b66e465582c3f0dc36.jpeg\" class=\"thumbnail\" width=\"247\" height=\"330\"></div>\n\n<h3><a href=\"https://wfkelley.com/2017/06/13/ridge-monte-bello-a-study-in-singularity/\" target=\"_blank\" rel=\"noopener nofollow ugc\">Ridge Monte Bello: a study in singularity</a></h3>\n\n  <p>An expanded version of this article can be found at www.robertparker.com.</p>\n\n\n  </article>\n\n  <div class=\"onebox-metadata\">\n    \n    \n  </div>\n\n  <div style=\"clear: both\"></div>\n</aside>\n",
