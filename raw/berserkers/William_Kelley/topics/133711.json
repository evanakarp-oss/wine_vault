        "avatar_template": "/letter_avatar_proxy/v4/letter/d/b487fb/{size}.png",
        "created_at": "2017-06-14T17:06:05.000Z",
        "cooked": "<aside class=\"onebox allowlistedgeneric\" data-onebox-src=\"https://napavalleyregister.com/news/local/freak-hail-storm-causes-vine-damage-in-some-napa-valley/article_a11cc817-ea49-56a6-8d69-c1ade2d007b6.html\">\n  <header class=\"source\">\n      <img src=\"https://www.wineberserkers.com/uploads/db0731/original/3X/7/c/7c2caaa2fc54086a20a619764434274b18c1724a.png\" class=\"site-icon\" width=\"16\" height=\"16\">\n\n      <a href=\"https://napavalleyregister.com/news/local/freak-hail-storm-causes-vine-damage-in-some-napa-valley/article_a11cc817-ea49-56a6-8d69-c1ade2d007b6.html\" target=\"_blank\" rel=\"noopener nofollow ugc\">Napa Valley Register</a>\n  </header>\n\n  <article class=\"onebox-body\">\n    <img src=\"https://www.wineberserkers.com/uploads/db0731/original/3X/8/d/8d9e252a7cc35a4217e90c8faa2b972e696a63a3.jpeg\" class=\"thumbnail onebox-avatar\" width=\"200\" height=\"200\">\n\n<h3><a href=\"https://napavalleyregister.com/news/local/freak-hail-storm-causes-vine-damage-in-some-napa-valley/article_a11cc817-ea49-56a6-8d69-c1ade2d007b6.html\" target=\"_blank\" rel=\"noopener nofollow ugc\">Freak hail storm causes vine damage in some Napa Valley vineyards</a></h3>\n\n  <p>Many vineyards on Atlas Peak and Pritchard Hill and in Oakville apparently suffered extensive damage from Sunday afternoon\u2019s freak hail storm.</p>\n\n\n  </article>\n\n  <div class=\"onebox-metadata\">\n    \n    \n  </div>\n\n  <div style=\"clear: both\"></div>\n</aside>\n",
