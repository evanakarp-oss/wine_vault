        "avatar_template": "/letter_avatar_proxy/v4/letter/j/5f9b8f/{size}.png",
        "created_at": "2019-02-10T21:38:24.000Z",
        "cooked": "<p>Guigal wines are very well made. Shame about the oak flavour.</p>",
        "post_number": 6,
        "post_type": 1,
