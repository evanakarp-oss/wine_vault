      {
        "id": 2599741,
        "name": "Dale McClaran",
        "username": "Dale_McClaran",
        "avatar_template": "/user_avatar/www.wineberserkers.com/dale_mcclaran/{size}/683_2.png",
        "created_at": "2019-03-11T16:32:58.000Z",
        "cooked": "<p>I have yet to taste a 2014 Chablis that didn\u2019t hit the \u2018classic\u2019 profile to some degree, in many cases, textbook examples.</p>",
        "post_number": 5,
        "post_type": 1,
        "posts_count": 10,
