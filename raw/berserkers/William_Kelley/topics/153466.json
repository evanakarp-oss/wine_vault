      {
        "id": 2678055,
        "name": "William Kelley",
        "username": "William_Kelley",
        "avatar_template": "/user_avatar/www.wineberserkers.com/william_kelley/{size}/2314_2.png",
        "created_at": "2019-07-17T18:02:37.000Z",
        "cooked": "<p>One of the first producers to plant high-quality selections of Pinot Noir from the C\u00f4te d\u2019Or in the C\u00f4te Chalonnaise, breaking the vicious cycle that long held back that region\u2019s wines. 2017s are also very tasty, a bit more open-knit and front-loaded than 2016s, but for wines that will mostly be drunk comparatively young, that\u2019s not such a problem.</p>",
        "post_number": 4,
        "post_type": 1,
        "posts_count": 8,
        "updated_at": "2022-06-03T12:13:12.301Z",
        "reply_count": 0,
