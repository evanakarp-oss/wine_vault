      "image_url": "https://www.wineberserkers.com/uploads/db0731/optimized/4X/b/a/3/ba37ac10ed9b743487d6f60eba248a906c67256f_2_1024x768.jpeg",
      "created_at": "2025-07-14T02:31:06.639Z",
      "last_posted_at": "2025-07-14T02:48:49.616Z",
      "bumped": true,
      "bumped_at": "2025-07-14T02:48:49.616Z",
      "archetype": "regular",
      "unseen": false,
      "pinned": false,
