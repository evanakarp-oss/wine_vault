      {
        "id": 3119443,
        "name": null,
        "username": "Billbell",
        "avatar_template": "/letter_avatar_proxy/v4/letter/b/f6c823/{size}.png",
        "created_at": "2021-03-09T15:43:13.000Z",
        "cooked": "<p>William, I love Collin champagnes and have been buying them for some time\u2026what is your sense as to how long the pre-2016 releases can age and when do they seem to reach their peak?</p>",
        "post_number": 7,
        "post_type": 1,
        "posts_count": 8,
        "updated_at": "2022-06-04T02:50:41.363Z",
        "reply_count": 1,
        "reply_to_post_number": null,
        "quote_count": 0,
        "incoming_link_count": 2,
        "reads": 17,
        "readers_count": 16,
        "score": 18.4,
        "yours": false,
        "topic_id": 169013,
        "topic_slug": "tn-2015-ulysse-collin-blanc-de-noirs-les-maillons",
        "display_username": null,
        "primary_group_name": "Grand_Cru_Cru",
        "flair_name": "Grand_Cru_Cru",
        "flair_url": "/uploads/db3686/original/1X/7b2f760f75c0451c5893edff1334577c6de1c89b.png",
        "flair_bg_color": "",
        "flair_color": "",
