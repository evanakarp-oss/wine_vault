      {
        "id": 2861936,
        "name": "Greg Kahn",
        "username": "Greg_K",
        "avatar_template": "/letter_avatar_proxy/v4/letter/g/ecccb3/{size}.png",
        "created_at": "2020-04-10T12:52:54.000Z",
        "cooked": "<p>Early 80s Guigal Hermitages are nice wines, though I\u2019ve never found them to be overly complex.  That said, they\u2019re better than any 1980 Bordeaux I\u2019ve ever had.</p>",
        "post_number": 8,
